# VEXA Production Environment Template
# Copy to .env.local (frontend) and backend/.env, fill in real values.
# NEVER commit files with real secrets.

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...              # public anon key (safe to expose)
SUPABASE_SERVICE_ROLE_KEY=eyJ...                  # NEVER expose to client — server only

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=abc123def456
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-key          # NEVER log
R2_BUCKET_NAME=vexa-assets
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# ── AI Providers ──────────────────────────────────────────────────────────────
TNB_API_KEY=tnb_xxxxxxxxxxxx                      # NEVER put in URLs — header only
OPENAI_API_KEY=sk-xxxxxxxxxxxx                    # NEVER log
MESHY_API_KEY=msy-xxxxxxxxxxxx
BLACKBOX_API_KEY=xxxxxxxxxxxx
ANAKIN_API_KEY=xxxxxxxxxxxx
BYTEDANCE_API_KEY=xxxxxxxxxxxx

# ── Transactional Email ───────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx

# ── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"

# ── Internal Services ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=change-me-generate-with-openssl-rand-hex-32   # REQUIRED in production
PYTHON_SERVICE_URL=http://backend:8000
AVATAR_SERVICE_URL=http://backend:8000
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ── Admin ─────────────────────────────────────────────────────────────────────
VEXA_ADMIN_KEY=change-me-generate-with-openssl-rand-hex-32

# ── Observability ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx

# ── Backend-only (backend/.env) ───────────────────────────────────────────────
ENVIRONMENT=production                            # Set to 'development' only locally
ALLOWED_ORIGINS=https://yourdomain.com
SMPLX_MODEL_PATH=models/
SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
